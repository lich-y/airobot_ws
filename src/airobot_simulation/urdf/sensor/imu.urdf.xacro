<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="imu_macro">
	<!-- IMU(惯性测量单元)传感器宏定义 -->
	<!-- 参数: name(传感器名称), parent(父链接), xyz(安装位置) -->
	<xacro:macro name="imu" params="name parent xyz">
		<!-- IMU参数 -->
		<xacro:property name="imu_mass" value="0.05"/>      <!-- IMU质量(千克) -->
		<xacro:property name="imu_size" value="0.025"/>    <!-- IMU尺寸(米,立方体边长) -->

		<link name="${name}_link">
			<visual>
				<origin xyz="0 0 0" rpy="0 0 0"/>
				<geometry>
					<box size="${imu_size} ${imu_size} ${imu_size}"/>
				</geometry>
				<material name="orange">
					<color rgba="0.95 0.55 0.15 1.0"/>
				</material>
			</visual>

			<collision>
				<origin xyz="0 0 0" rpy="0 0 0"/>
				<geometry>
					<box size="${imu_size} ${imu_size} ${imu_size}"/>
				</geometry>
			</collision>

			<inertial>
				<origin xyz="0 0 0" rpy="0 0 0"/>
				<mass value="${imu_mass}"/>
				<inertia ixx="1.0e-5" ixy="0.0" ixz="0.0" iyy="1.0e-5" iyz="0.0" izz="1.0e-5"/>
			</inertial>
		</link>

		<joint name="${name}_joint" type="fixed">
			<parent link="${parent}"/>
			<child link="${name}_link"/>
			<origin xyz="${xyz}" rpy="0 0 0"/>
		</joint>
	</xacro:macro>
</robot>
